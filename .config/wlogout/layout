{
    "label" : "logout (l)",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Logout",
    "keybind" : "l"
}
{
    "label" : "shutdown (s)",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend (u)",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot (r)",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
