{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Logout (L)",
    "keybind" : "l"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown (S)",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend (U)",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot (R)",
    "keybind" : "r"
}
